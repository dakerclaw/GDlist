# GDList — 环境变量配置模板
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
#   nano .env

# ── 服务端口 ────────────────────────────────────────────────────────────────
PORT=3000

# ── 会话密钥（随机生成，勿泄露）────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-random-secret

# ── 管理员账号 ─────────────────────────────────────────────────────────────
# 用户名
ADMIN_USERNAME=admin
# 密码哈希（由 install.sh 自动生成，无需手动填写）
# 生成方式：node -e "const b=require('bcryptjs');b.hash('你的密码',10).then(h=>console.log(h))"
ADMIN_PASSWORD_HASH=

# ── Google Drive Service Account ───────────────────────────────────────────
# Service Account JSON 密钥文件的绝对路径（必须）
# 详见 README.md 第 2 步：创建 Service Account 并下载密钥
GOOGLE_SERVICE_ACCOUNT_JSON=/opt/gdlist/service-account-key.json
